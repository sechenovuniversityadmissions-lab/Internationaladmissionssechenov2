	    		1670: {items: 5}
	    	},
	        pagination : false
	    });
	    $('.medialibrary .medialibrary-next').click(function(){
	      ml.trigger('next.owl.carousel');
	    });
	    $('.medialibrary .medialibrary-prev').click(function(){
	      ml.trigger('prev.owl.carousel');
	    });
