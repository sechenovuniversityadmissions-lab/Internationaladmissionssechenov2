	    });
	    $('.nav-v-left').click(function(){
	      mv.trigger('owl.prev');
	    });


	//карусель в новостях детально	
	var np = $('.news-galery');
		np.owlCarousel({
	        items : 4,
	        itemsCustom : false,
	        itemsDesktop : [1400,3],  
	        itemsTablet: [992,3],
	        itemsTabletSmall: [900,2],
	        itemsMobile : [600,1],
	        pagination : false
	    });
