	$('.f-banner-item').css('width', fBannerLength + '%');

	//слайдер в модальном окне в видео
	var mv = $('.modal-footer-slider-inner');
		mv.owlCarousel({
	        items : 3,
	        itemsCustom : false,
	        itemsDesktop : [1600,3],  
	        itemsTablet: [992,2],
	        itemsTabletSmall: [767,1],
	        itemsMobile : [600,1],
	        pagination : false
